# ─────────────────────────────────────────────────────────────────────────────
# REVERSE-OS — environment configuration
# Copy to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                             # development | production
APP_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
LICENSE_KEY=                                    # Leave empty for free tier (100 returns/month)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reverseos

# ── PII Encryption (AES-256, base64 encoded 32-byte key) ─────────────────────
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
PII_ENCRYPTION_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── eCommerce ─────────────────────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

MAGENTO_BASE_URL=
MAGENTO_ACCESS_TOKEN=

# ── Logistics ─────────────────────────────────────────────────────────────────
INPOST_API_TOKEN=

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=

# ── KSeF / ERP ────────────────────────────────────────────────────────────────
COMPANY_NAME=Your Company Sp. z o.o.
COMPANY_NIP=0000000000
COMPANY_ADDRESS=ul. Przykładowa 1, 00-001 Warszawa
ERP_WEBHOOK_URL=                                # POST endpoint for FA(2) correction payloads

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_RULE_ENGINE=true
ENABLE_AUTO_REFUND=false                        # Enterprise license required
